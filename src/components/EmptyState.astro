---
interface Props {
  title: string;
  body: string;
}
const { title, body } = Astro.props;
---
<div class="empty-state reveal">
  <svg class="glyph" viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-linecap="round" aria-hidden="true">
    <path d="M60 20 C60 45 60 65 60 100" stroke-width="2"/>
    <path d="M56 40 C40 50 28 58 14 62" stroke-width="1.6"/>
    <path d="M64 40 C80 50 92 58 106 62" stroke-width="1.6"/>
    <path d="M58 60 C46 66 38 70 26 72" stroke-width="1.2" opacity="0.7"/>
    <path d="M62 60 C74 66 82 70 94 72" stroke-width="1.2" opacity="0.7"/>
  </svg>
  <h3 class="script" style="font-size:1.8rem">{title}</h3>
  <p>{body}</p>
  <a class="btn btn-solid" href="/grace-notes/#signup">Join Grace Notes to hear first</a>
</div>
