---
import { getEntry } from 'astro:content';
import Logomark from './Logomark.astro';

const settings = await getEntry('settings', 'settings');
const s = settings!.data;
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <a class="brand" href="/" style="display:inline-flex;align-items:center;gap:12px">
          <Logomark />
          <span class="brand-name">Rooted in <span class="script">Grace</span></span>
        </a>
        <p style="margin-top:14px;max-width:36ch">{s.tagline}</p>
      </div>
      <div>
        <h4>Explore</h4>
        <ul>
          <li><a href="/stories/">Stories</a></li>
          <li><a href="/podcast/">Podcast</a></li>
          <li><a href="/journal/">Journal</a></li>
          <li><a href="/events/">Events</a></li>
          <li><a href="/grace-notes/">Grace Notes</a></li>
        </ul>
      </div>
      <div>
        <h4>Community</h4>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/share/">Share Your Story</a></li>
          <li><a href="/community/">Community</a></li>
          <li><a href="/partner/">Partner With Us</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
    </div>
    <p class="wellness">{s.wellnessDisclaimer}</p>
    <p class="copyright">&copy; {year} Rooted in Grace. Made with care.</p>
  </div>
</footer>
