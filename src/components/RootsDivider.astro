---
interface Props {
  variant?: 'divider' | 'hero';
}
const { variant = 'divider' } = Astro.props;
---
{variant === 'hero' ? (
  <svg class="hero-roots" viewBox="0 0 680 60" fill="none" stroke="currentColor" stroke-linecap="round" aria-hidden="true">
    <path d="M340 0 C340 22 340 40 340 58" stroke-width="2"/>
    <path d="M336 6 C300 26 240 38 150 44" stroke-width="1.6"/>
    <path d="M344 6 C380 26 440 38 530 44" stroke-width="1.6"/>
    <path d="M330 10 C290 24 250 30 200 32" stroke-width="1.1" opacity="0.7"/>
    <path d="M350 10 C390 24 430 30 480 32" stroke-width="1.1" opacity="0.7"/>
  </svg>
) : (
  <svg class="roots-divider" viewBox="0 0 420 34" fill="none" stroke="currentColor" stroke-linecap="round" aria-hidden="true">
    <path d="M210 2 C210 12 210 20 210 30" stroke-width="1.8"/>
    <path d="M206 8 C180 18 140 24 90 26" stroke-width="1.3"/>
    <path d="M214 8 C240 18 280 24 330 26" stroke-width="1.3"/>
    <path d="M195 14 C170 20 150 22 120 22" stroke-width="1" opacity="0.7"/>
    <path d="M225 14 C250 20 270 22 300 22" stroke-width="1" opacity="0.7"/>
  </svg>
)}
