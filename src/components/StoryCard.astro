---
import type { CollectionEntry } from 'astro:content';

interface Props {
  story: CollectionEntry<'stories'>;
}
const { story } = Astro.props;
const { title, excerpt, authorName, isAnonymous, publishDate, cover, coverAlt } = story.data;
const dateStr = publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<a class="story-card reveal" href={`/stories/${story.slug}/`} style="text-decoration:none;display:block">
  <span class="tag">From the Sidewalk</span>
  {cover && <img src={cover} alt={coverAlt || ''} width="640" height="360" style="border-radius:12px;margin-bottom:20px;object-fit:cover;aspect-ratio:16/9;width:100%" loading="lazy" />}
  <h3>{title}</h3>
  <p>{excerpt}</p>
  <p class="meta">{isAnonymous ? 'Anonymous' : authorName || 'Anonymous'} &middot; {dateStr}</p>
</a>
