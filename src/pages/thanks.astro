---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Thank You"
  description="Your message has been received."
>
  <section class="error-page">
    <div class="wrap">
      <span class="script">Thank you</span>
      <h1>You're on the list — welcome home.</h1>
      <p>Whatever you just sent us, it landed safely. We'll be in touch when it matters, and never before.</p>
      <a class="btn btn-solid" href="/">Back to the sanctuary</a>
    </div>
  </section>
</BaseLayout>
