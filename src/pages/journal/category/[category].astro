---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import JournalCard from '../../../components/JournalCard.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { categories } from '../../../lib/categories';

export async function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat.toLowerCase() },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const posts = (await getCollection('journal', (post) => post.data.category === category)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---
<BaseLayout
  title={`${category} — The Journal`}
  description={`Reflections on ${category.toLowerCase()} from the Rooted in Grace journal.`}
>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow" style="justify-content:center;color:var(--sage)">The Journal</span>
      <h1>{category}</h1>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="filter-tabs">
        <a href="/journal/">All</a>
        {categories.map((cat) => (
          <a href={`/journal/category/${cat.toLowerCase()}/`} class={cat === category ? 'active' : ''}>{cat}</a>
        ))}
      </div>
      {posts.length > 0 ? (
        <div class="cards">
          {posts.map((post) => <JournalCard post={post} />)}
        </div>
      ) : (
        <EmptyState
          title={`No ${category.toLowerCase()} posts yet`}
          body="This category is still growing. Join Grace Notes to know the moment something new is published here."
        />
      )}
    </div>
  </section>
</BaseLayout>
