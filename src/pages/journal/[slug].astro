---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SampleBadge from '../../components/SampleBadge.astro';

export async function getStaticPaths() {
  const posts = await getCollection('journal');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, category, excerpt, publishDate, cover, coverAlt, isSample } = post.data;
const { Content } = await post.render();
const dateStr = publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<BaseLayout title={title} description={excerpt} image={cover?.src}>
  <article>
    <div class="article-hero">
      <div class="wrap">
        <span class="cat">{category}</span>
        <h1>{title}</h1>
        <p class="meta">{dateStr}</p>
      </div>
    </div>
    {cover && (
      <div class="article-cover">
        <Image src={cover} alt={coverAlt || ''} width={880} height={495} />
      </div>
    )}
    <div class="article-body">
      {isSample && <SampleBadge />}
      <Content />
      <p><a class="article-back" href="/journal/">&larr; Back to the Journal</a></p>
    </div>
  </article>
</BaseLayout>
