---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found"
  description="This page seems to have wandered off."
>
  <section class="error-page">
    <div class="wrap">
      <span class="script">Lost, not forgotten</span>
      <h1>We couldn't find that page</h1>
      <p>Even the roots don't reach everywhere. Let's get you back to solid ground.</p>
      <a class="btn btn-solid" href="/">Back to the sanctuary</a>
    </div>
  </section>
</BaseLayout>
