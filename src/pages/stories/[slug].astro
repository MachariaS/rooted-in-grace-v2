---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SampleBadge from '../../components/SampleBadge.astro';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { title, excerpt, authorName, isAnonymous, publishDate, cover, coverAlt, isSample } = story.data;
const { Content } = await story.render();
const dateStr = publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<BaseLayout title={title} description={excerpt} image={cover?.src}>
  <article>
    <div class="article-hero">
      <div class="wrap">
        <span class="cat">From the Sidewalk</span>
        <h1>{title}</h1>
        <p class="meta">{isAnonymous ? 'Anonymous' : authorName || 'Anonymous'} &middot; {dateStr}</p>
      </div>
    </div>
    {cover && (
      <div class="article-cover">
        <Image src={cover} alt={coverAlt || ''} width={880} height={495} />
      </div>
    )}
    <div class="article-body">
      {isSample && <SampleBadge />}
      <Content />
      <p><a class="article-back" href="/stories/">&larr; Back to all stories</a></p>
    </div>
  </article>
</BaseLayout>
